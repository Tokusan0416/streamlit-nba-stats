# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Google Cloud Project
GCP_PROJECT_ID=your-project-id

# BigQuery Tables
PLAYER_SEASON_STATS_TABLE=your-project-id.nba_stats.fact_player_season_stats

# NBA API Settings (Optional - defaults are provided)
# NBA_API_RATE_LIMIT_DELAY=2.0
# NBA_API_TIMEOUT=30

# Data Range (Optional - defaults are provided)
# HISTORICAL_START_YEAR=1997
# CURRENT_YEAR=2025

# BigQuery Settings (Optional - defaults are provided)
# BIGQUERY_WRITE_DISPOSITION=WRITE_APPEND
